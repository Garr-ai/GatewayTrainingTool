{
  "buildCommand": "npm install && cd web && npm install && npm run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/src/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
