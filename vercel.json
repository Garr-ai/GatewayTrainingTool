{
  "buildCommand": "cd web && npm install && npm run build && cd ../api && npm install",
  "outputDirectory": "web/dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "api/src/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
